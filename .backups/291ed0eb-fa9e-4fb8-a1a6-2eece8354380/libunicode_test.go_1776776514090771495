package unicode

import (
	"testing"
	"unicode"
)

func TestIsSpaceByte(t *testing.T) {
	testCases := []struct {
		c   uint8
		res bool
	}{
		{' ', true},
		{'\t', true},
		{'\n', true},
		{'\r', true},
		{'a', false},
		{'0', false},
		{'_', false},
		{'$', false},
	}

	for _, tc := range testCases {
		if got := IsSpaceByte(tc.c); got != tc.res {
			t.Errorf("IsSpaceByte(%q) = %v, want %v", tc.c, got, tc.res)
		}
	}
}

