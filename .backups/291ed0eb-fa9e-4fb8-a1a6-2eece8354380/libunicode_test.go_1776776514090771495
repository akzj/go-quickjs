func TestIsSpace(t *testing.T) {
	testCases := []struct {
		c   uint32
		res bool
	}{
		{' ', true},
		{'\t', true},
		{0x00A0, true}, // non-breaking space
		{'a', false},
		{0x4E00, false}, // Chinese character
	}

	for _, tc := range testCases {
		if got := IsSpace(tc.c); got != tc.res {
			t.Errorf("IsSpace(%#U) = %v, want %v", tc.c, got, tc.res)
		}
	}
}

func TestJSIsIdentFirst(t *testing.T) {
	testCases := []struct {
		c   uint32
		res bool
	}{
		{'a', true},
		{'Z', true},
		{'_', true},
		{'$', true},
		{'0', false},
		{0x4E00, true}, // Chinese character (unicode letter)
		{0x3042, true}, // Hiragana
		{0x200C, false}, // ZWNJ
	}

	for _, tc := range testCases {
		if got := JSIsIdentFirst(tc.c); got != tc.res {
			t.Errorf("JSIsIdentFirst(%#U) = %v, want %v", tc.c, got, tc.res)
		}
	}
}

func TestJSIsIdentNext(t *testing.T) {
	testCases := []struct {
		c   uint32
		res bool
	}{
		{'a', true},
		{'Z', true},
		{'_', true},
		{'$', true},
		{'0', true},
		{0x4E00, true}, // Chinese character
		{0x200C, true}, // ZWNJ allowed in continue
		{0x200D, true}, // ZWJ allowed in continue
		{' ', false},
	}

	for _, tc := range testCases {
		if got := JSIsIdentNext(tc.c); got != tc.res {
			t.Errorf("JSIsIdentNext(%#U) = %v, want %v", tc.c, got, tc.res)
		}
	}
}
