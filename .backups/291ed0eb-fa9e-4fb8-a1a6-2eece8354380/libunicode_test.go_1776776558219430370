func TestCRCopy(t *testing.T) {
	var cr1, cr2 CharRange
	CRInit(&cr1, nil, nil)
	defer CRFree(&cr1)
	CRInit(&cr2, nil, nil)
	defer CRFree(&cr2)

	// Add intervals to cr1
	CRAddInterval(&cr1, 'a', 'z')
	CRAddInterval(&cr1, '0', '9')

	// Copy to cr2
	if ret := CRCopy(&cr2, &cr1); ret != 0 {
		t.Errorf("CRCopy returned %d, want 0", ret)
	}

	// Verify copy
	if cr2.Len != cr1.Len {
		t.Errorf("CRCopy: Len = %d, want %d", cr2.Len, cr1.Len)
	}
}

func TestCROp(t *testing.T) {
	var cr CharRange
	CRInit(&cr, nil, nil)
	defer CRFree(&cr)

	// Test union: [a-f] U [d-k] = [a-k]
	aPt := []uint32{'a', 'g'} // [a, f]
	bPt := []uint32{'d', 'l'} // [d, k]

	if ret := CROp(&cr, aPt, 2, bPt, 2, CR_OP_UNION); ret != 0 {
		t.Errorf("CROp UNION returned %d, want 0", ret)
	}

	// Result should be [a, l] (merged)
	if cr.Len != 2 || cr.Points[0] != 'a' || cr.Points[1] != 'l'+1 {
		t.Errorf("CROp UNION result = %v, want [a, l+1)", cr.Points[:cr.Len])
	}
}

func TestCRInvert(t *testing.T) {
	var cr CharRange
	CRInit(&cr, nil, nil)
	defer CRFree(&cr)

	// Invert [a-f] = everything except [a-f]
	CRAddInterval(&cr, 'a', 'f')

	if ret := CRInvert(&cr); ret != 0 {
		t.Errorf("CRInvert returned %d, want 0", ret)
	}

	// Should start with 0
	if cr.Len < 2 || cr.Points[0] != 0 {
		t.Errorf("CRInvert: first point = %d, want 0", cr.Points[0])
	}
}

func TestCharRangeBasic(t *testing.T) {
	var cr CharRange
	CRInit(&cr, nil, nil)
	defer CRFree(&cr)

	// Test CRAddPoint
	for i := uint32(0); i < 10; i++ {
		if ret := CRAddPoint(&cr, i); ret != 0 {
			t.Errorf("CRAddPoint(%d) returned %d, want 0", i, ret)
		}
	}

	if cr.Len != 10 {
		t.Errorf("CRAddPoint: Len = %d, want 10", cr.Len)
	}
}
