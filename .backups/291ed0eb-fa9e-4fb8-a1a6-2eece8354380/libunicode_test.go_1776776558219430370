func TestLRECaseConv(t *testing.T) {
	testCases := []struct {
		c         uint32
		convType  int
		expected  []uint32
		resultLen int
	}{
		// ASCII to upper
		{'a', 0, []uint32{'A'}, 1},
		{'z', 0, []uint32{'Z'}, 1},
		// ASCII to lower
		{'A', 1, []uint32{'a'}, 1},
		{'Z', 1, []uint32{'z'}, 1},
		// Greek sigma special cases
		{0x03A3, 0, []uint32{0x03A3}, 1}, // Sigma stays Sigma
		// Non-cased characters unchanged
		{'1', 0, []uint32{'1'}, 1},
	}

	for _, tc := range testCases {
		res := make([]uint32, LRE_CC_RES_LEN_MAX)
		got := LRECaseConv(res, tc.c, tc.convType)
		if got != tc.resultLen {
			t.Errorf("LRECaseConv(%#U, %d) len = %d, want %d", tc.c, tc.convType, got, tc.resultLen)
			continue
		}
		if res[0] != tc.expected[0] {
			t.Errorf("LRECaseConv(%#U, %d) = %#U, want %#U", tc.c, tc.convType, res[0], tc.expected[0])
		}
	}
}

func TestLRECanonicalize(t *testing.T) {
	testCases := []struct {
		c         uint32
		isUnicode bool
		expected  uint32
	}{
		// ASCII unicode mode
		{'A', true, 'a'},
		{'Z', true, 'z'},
		// ASCII legacy mode
		{'a', false, 'A'},
		{'z', false, 'Z'},
		// Non-cased
		{'1', true, '1'},
		{' ', true, ' '},
	}

	for _, tc := range testCases {
		got := LRECanonicalize(tc.c, tc.isUnicode)
		if got != tc.expected {
			t.Errorf("LRECanonicalize(%#U, %v) = %#U, want %#U", tc.c, tc.isUnicode, got, tc.expected)
		}
	}
}

