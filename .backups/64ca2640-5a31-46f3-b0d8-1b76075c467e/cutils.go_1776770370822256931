// PStrcpy copies a string to a buffer with truncation, null terminating the result
func PStrcpy(buf []byte, str string) {
	bufSize := len(buf)
	if bufSize <= 0 {
		return
	}
	n := MinInt(len(str), bufSize-1)
	copy(buf[:n], str)
	buf[n] = 0
}

// PStrcat appends a string to a buffer with truncation, null terminating the result
func PStrcat(buf []byte, s string) []byte {
	lenBuf := 0
	for lenBuf < len(buf) && buf[lenBuf] != 0 {
		lenBuf++
	}
	if lenBuf < len(buf) {
		PStrcpy(buf[lenBuf:], s)
	}
	return buf
}

// StrStart checks if str starts with val, returns true and the remaining part if it does
func StrStart(str, val string) (bool, string) {
	if len(str) < len(val) {
		return false, str
	}
	for i := 0; i < len(val); i++ {
		if str[i] != val[i] {
			return false, str
		}
	}
	return true, str[len(val):]
}

// HasSuffix checks if str ends with suffix
func HasSuffix(str, suffix string) bool {
	if len(str) < len(suffix) {
		return false
	}
	return str[len(str)-len(suffix):] == suffix
}

// Clz32 returns the number of leading zero bits in a uint32, undefined if a is 0
func Clz32(a uint32) int {
	return 31 - int(math.Log2(float64(a)))
}

// Clz64 returns the number of leading zero bits in a uint64, undefined if a is 0
func Clz64(a uint64) int {
	return 63 - int(math.Log2(float64(a)))
}

// Ctz32 returns the number of trailing zero bits in a uint32, undefined if a is 0
func Ctz32(a uint32) int {
	if a == 0 {
		return 32
	}
	n := 0
	for (a & 1) == 0 {
		n++
		a >>= 1
	}
	return n
}

// Ctz64 returns the number of trailing zero bits in a uint64, undefined if a is 0
func Ctz64(a uint64) int {
	if a == 0 {
		return 64
	}
	n := 0
	for (a & 1) == 0 {
		n++
		a >>= 1
	}
	return n
}

